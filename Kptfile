apiVersion: kpt.dev/v1
kind: Kptfile
metadata:
  name: config-sync-demo
  annotations:
    config.kubernetes.io/local-config: "true"
info:
  description: mutators + local policy validators
pipeline:
  mutators:
    - image: ghcr.io/kptdev/krm-functions-catalog/set-labels:latest
      configPath: setters/set-labels.yaml
  validators:
    - image: ghcr.io/kptdev/krm-functions-catalog/kubeconform:latest
    - image: ghcr.io/kptdev/krm-functions-catalog/gatekeeper:latest
status:
  conditions:
    - type: Rendered
      status: "True"
      reason: RenderSuccess
  renderStatus:
    mutationSteps:
      - image: ghcr.io/kptdev/krm-functions-catalog/set-labels:latest
        exitCode: 0
        results:
          - message: set 16 labels in total
            severity: info
    validationSteps:
      - image: ghcr.io/kptdev/krm-functions-catalog/kubeconform:latest
        exitCode: 0
      - image: ghcr.io/kptdev/krm-functions-catalog/gatekeeper:latest
        exitCode: 0
